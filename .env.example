# Lampad AtlasBridge runs entirely on-device. No cloud AI keys required.
#
# The only environment variables are for the optional offline-SOS sync backend
# (see render.yaml). They are NOT needed to run the app locally or to use any
# of the on-device LLM / retrieval features.

# VITE_SOS_ENDPOINT: endpoint that receives queued SOS packets when connectivity returns.
VITE_SOS_ENDPOINT=""

# VITE_BACKEND_WEBHOOK_BASE: base URL for backend webhooks.
VITE_BACKEND_WEBHOOK_BASE=""
